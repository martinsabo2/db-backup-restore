# Required
AZURE_STORAGE_ACCOUNT_NAME=yourstorageaccount
AZURE_BLOB_CONTAINER_NAME=your-container-name
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000
AZURE_BACKUP_VAULT_RESOURCE_GROUP=rg-backup-vault
AZURE_BACKUP_VAULT_NAME=myBackupVault
AZURE_BACKUP_INSTANCE_NAME=myBlobBackupInstance
AZURE_BACKUP_RESTORE_LOCATION=eastus

# Optional: If omitted, code builds https://<account>.blob.core.windows.net
# AZURE_STORAGE_ACCOUNT_URL=https://yourstorageaccount.blob.core.windows.net

# Optional: Set for user-assigned managed identity; leave empty for system-assigned
# AZURE_MANAGED_IDENTITY_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Optional: one of none, blob, container
AZURE_BLOB_PUBLIC_ACCESS=none

# Optional: API version used for Data Protection calls.
AZURE_BACKUP_API_VERSION=2025-09-01

# Optional: usually VaultStore for vaulted blob backups.
AZURE_BACKUP_SOURCE_DATA_STORE_TYPE=VaultStore

# Optional: validation prefix for backup instance datasource type.
# PostgreSQL defaults to Microsoft.DBforPostgreSQL/
AZURE_BACKUP_EXPECTED_DATASOURCE_TYPE_PREFIX=Microsoft.DBforPostgreSQL/

# Optional: prefix used when restore creates files in target blob container.
AZURE_BACKUP_RESTORE_FILE_PREFIX=restored

# Optional: polling controls for async restore operation.
AZURE_BACKUP_RESTORE_POLL_SECONDS=15
AZURE_BACKUP_RESTORE_TIMEOUT_SECONDS=1800
